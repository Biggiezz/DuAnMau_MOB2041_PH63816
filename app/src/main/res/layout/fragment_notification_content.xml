<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp"
    tools:context=".notification.config.NotificationContentFragment">

    <TextView
        android:id="@+id/txtNotificationTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/notification"
        android:textColor="@color/color_title"
        android:textSize="24sp"
        android:textStyle="bold"
        tools:text="Thanh toán thành công" />

    <TextView
        android:id="@+id/txtNotificationMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="@string/placeholder_coming_soon"
        android:textColor="@color/color_subtitle"
        android:textSize="16sp"
        tools:text="Đơn hàng của bạn đã được ghi nhận." />

</LinearLayout>
