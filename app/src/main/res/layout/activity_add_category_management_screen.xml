<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical"
    tools:context=".category.AddCategoryManagementScreen">

    <LinearLayout
        style="@style/PageHeaderContainer"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbarAddCategoryManagementScreen"
            style="@style/PageToolbar"
            app:navigationIcon="@drawable/ic_back"
            app:title="Thêm danh mục mới" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="@string/category_icon"
        android:textColor="@color/color_title"
        android:textStyle="bold" />

    <Spinner
        android:id="@+id/spinnerCategoryIcon"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:spinnerMode="dropdown" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="Tên danh mục"
        android:textColor="@color/color_title"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/edtNameCategory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:background="@drawable/bg_edit_text"
        android:fontFamily="@font/work_sans_medium"
        android:hint="Ví dụ: Đồ uống, Thực phẩm tươi sống..."
        android:inputType="text"
        android:textColor="@color/color_title"
        android:textColorHint="@color/color_hint"
        android:textSize="14sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="Mã danh mục"
        android:textColor="@color/color_title"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/edtCodeCategory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:background="@drawable/bg_edit_text"
        android:fontFamily="@font/work_sans_medium"
        android:hint="Ví dụ: 5"
        android:inputType="number"
        android:textColor="@color/color_title"
        android:textColorHint="@color/color_hint"
        android:textSize="14sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="Số lượng sản phẩm"
        android:textColor="@color/color_title"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/edtCountCategory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:background="@drawable/bg_edit_text"
        android:fontFamily="@font/work_sans_medium"
        android:hint="Ví dụ: 50"
        android:inputType="number"
        android:textColor="@color/color_title"
        android:textColorHint="@color/color_hint"
        android:textSize="14sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="Mô tả chi tiết"
        android:textColor="@color/color_title"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/edtDescribeCategory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:background="@drawable/bg_edit_text"
        android:fontFamily="@font/work_sans_medium"
        android:gravity="top|start"
        android:hint="Nhập mô tả ngắn gọn về danh mục này..."
        android:inputType="textMultiLine"
        android:minLines="4"
        android:textColor="@color/color_title"
        android:textColorHint="@color/color_hint"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btnAddCategory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:backgroundTint="@color/color_default"
        android:elevation="2dp"
        android:padding="12dp"
        android:text="Lưu danh mục"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="8dp" />

</LinearLayout>
