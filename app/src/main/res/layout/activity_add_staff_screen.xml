<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <!-- TOOLBAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="?actionBarSize"
        android:background="@color/white"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/icBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_back" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/work_sans_medium"
            android:text="Thêm nhân viên mới"
            android:textColor="@color/color_title"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1A000000" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="64dp">

            <!-- Avatar -->
            <FrameLayout
                android:layout_width="100dp"
                android:layout_height="100dp">
                
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="20dp"
                    android:src="@drawable/ic_profile" 
                    app:strokeColor="#FCE7F3"
                    app:strokeWidth="2dp" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/bg_badge_vip" 
                    android:backgroundTint="@color/color_default"
                    android:padding="5dp"
                    android:src="@drawable/ic_edit"
                    app:tint="@color/white" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/work_sans_medium"
                android:text="Ảnh đại diện"
                android:textColor="@color/color_title"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"
                android:fontFamily="@font/work_sans"
                android:text="Nhấn để tải lên ảnh nhân viên"
                android:textColor="@color/color_subtitle"
                android:textSize="12sp" />

            <!-- Input Fields -->
            <EditText
                android:id="@+id/edtStaffId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_edit_text"
                android:fontFamily="@font/work_sans_medium"
                android:hint="Mã nhân viên"
                android:inputType="text"
                android:textColor="@color/color_title"
                android:textColorHint="@color/color_hint"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/edtStaffName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_edit_text"
                android:fontFamily="@font/work_sans_medium"
                android:hint="Họ tên *"
                android:inputType="textPersonName"
                android:textColor="@color/color_title"
                android:textColorHint="@color/color_hint"
                android:textSize="14sp" />

            <AutoCompleteTextView
                android:id="@+id/actvRole"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_edit_text"
                android:fontFamily="@font/work_sans_medium"
                android:hint="Chức vụ"
                android:inputType="none"
                android:drawableEnd="@android:drawable/arrow_down_float"
                android:textColor="@color/color_title"
                android:textColorHint="@color/color_hint"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/edtStaffPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_edit_text"
                android:fontFamily="@font/work_sans_medium"
                android:hint="Số điện thoại *"
                android:inputType="phone"
                android:textColor="@color/color_title"
                android:textColorHint="@color/color_hint"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/edtStaffEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_edit_text"
                android:fontFamily="@font/work_sans_medium"
                android:hint="Email"
                android:inputType="textEmailAddress"
                android:textColor="@color/color_title"
                android:textColorHint="@color/color_hint"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/edtStaffAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_edit_text"
                android:fontFamily="@font/work_sans_medium"
                android:gravity="top|start"
                android:hint="Địa chỉ"
                android:inputType="textMultiLine"
                android:lines="3"
                android:textColor="@color/color_title"
                android:textColorHint="@color/color_hint"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveStaff"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:backgroundTint="@color/color_default"
                android:fontFamily="@font/work_sans_medium"
                android:letterSpacing="0"
                android:text="Lưu thay đổi"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                app:cornerRadius="8dp" />

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM MENU -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/white"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:weightSum="4">

        <com.example.DuAnMau_PH63816.custom.CustomBottomButton
            android:id="@+id/btnHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            app:btnIcon="@drawable/ic_home" />

        <com.example.DuAnMau_PH63816.custom.CustomBottomButton
            android:id="@+id/btnCart"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            app:btnIcon="@drawable/ic_product" />

        <com.example.DuAnMau_PH63816.custom.CustomBottomButton
            android:id="@+id/btnNotification"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            app:btnIcon="@drawable/ic_notification" />

        <com.example.DuAnMau_PH63816.custom.CustomBottomButton
            android:id="@+id/btnProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            app:btnIcon="@drawable/ic_setting" />

    </LinearLayout>

</LinearLayout>
